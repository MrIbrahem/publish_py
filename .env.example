# toolforge envvars create FLASK_SECRET_KEY "......"

# python -c "import secrets; print(secrets.token_hex(16))"
FLASK_SECRET_KEY=......

MAIN_DIR=I:/mdwiki/publish_py/data
FIX_REFS_PY_PATH=

TOOL_TOOLSDB_DBNAME=publish_py

TOOL_TOOLSDB_HOST=tools.db.svc.wikimedia.cloud
TOOL_TOOLSDB_USER=root
TOOL_TOOLSDB_PASSWORD=root11

OAUTH_MWURI=https://meta.wikimedia.org/w/index.php
OAUTH_CONSUMER_KEY=your_consumer_key
OAUTH_CONSUMER_SECRET=your_consumer_secret

# Generate URL-safe 32-byte Fernet key:
# python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
OAUTH_ENCRYPTION_KEY=....

AUTH_COOKIE_NAME=uid_enc
AUTH_COOKIE_MAX_AGE=2592000  # 30 days
SESSION_COOKIE_SAMESITE=Lax

SESSION_COOKIE_SECURE=1
SESSION_COOKIE_HTTPONLY=1
USE_MW_OAUTH=1

USER_AGENT="My Tool/1.0 (https://tool.toolforge.org; tools.tool@toolforge.org)"

REQUEST_TOKEN_SESSION_KEY=state
STATE_SESSION_KEY=oauth_state

FLASK_ENV=development
REVIDS_API_URL=http://localhost:9001/api
ALL_PAGES_REVIDS_PATH="I:/MD_TOOLS/MDWIKI_MAIN_REPO/public_html/all_pages_revids.json"

# --------------------------------------------------------------------
# UI Test Bypass (development-only — DO NOT use in production)
# --------------------------------------------------------------------
# When set to true AND the app is running with DevelopmentConfig, the
# coordinator authorization check (is_active_coordinator) is bypassed.
# This exists only to support local development and automated UI/E2E
# testing (Playwright, Selenium, browser automation) without needing a
# real row in the coordinators table.
#
# This flag is silently ignored under ProductionConfig — it has no
# effect there even if set to true. It must never be relied upon as a
# production authorization mechanism, and must remain false/unset when
# testing authorization or permission logic itself.
UI_TEST_BYPASS_COORDINATOR_CHECK=false
